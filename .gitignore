# local Node runtime (optional, for machines without npm on PATH)
.node/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# uploads (optional - remove if you want to track uploads)
public/uploads/images/*
public/uploads/videos/*
public/uploads/thumbnails/*
!public/uploads/images/.gitkeep
!public/uploads/videos/.gitkeep
!public/uploads/thumbnails/.gitkeep

# database
database/*.db
database/*.db-journal
